{
  "name": "better-github-stars-manager",
  "version": "1.0.6",
  "description": "Manage your GitHub starred repos: tag, note, filter, search across thousands of stars. UI injected into the stars page.",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "package:extension": "node scripts/package-extension.mjs",
    "prepare": "node scripts/setup-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node tests/commit-message.test.mjs && node tests/puppeteer-runtime.test.mjs && node --experimental-strip-types tests/ime-input.test.mjs && node --experimental-strip-types tests/tag-draft.test.mjs && node --experimental-strip-types tests/logic.test.ts && tsx tests/integration.test.ts && tsx tests/shape.test.ts && tsx tests/token-probe-and-status-regression.test.ts && tsx tests/rescan-regression.test.ts",
    "test:logic": "node --experimental-strip-types tests/logic.test.ts",
    "test:commit-message": "node tests/commit-message.test.mjs",
    "test:ime": "node --experimental-strip-types tests/ime-input.test.mjs",
    "test:tag-draft": "node --experimental-strip-types tests/tag-draft.test.mjs",
    "test:integration": "tsx tests/integration.test.ts",
    "test:shape": "tsx tests/shape.test.ts",
    "test:regressions": "tsx tests/token-probe-and-status-regression.test.ts",
    "test:smoke": "node tests/smoke.test.mjs",
    "test:verify-chrome": "node tests/verify-chrome.mjs",
    "test:verify-first-run": "node tests/verify-first-run.mjs",
    "test:reset-gist": "node tests/reset-gist-sync.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-virtual": "^3.10.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.279",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.49",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
