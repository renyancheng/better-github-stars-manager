{
  "name": "github-stars-manager",
  "version": "0.1.0",
  "description": "Manage your GitHub starred repos: tag, note, filter, search across 10k+ stars. UI injected into the stars page.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types tests/logic.test.ts && tsx tests/integration.test.ts && tsx tests/shape.test.ts",
    "test:logic": "node --experimental-strip-types tests/logic.test.ts",
    "test:integration": "tsx tests/integration.test.ts",
    "test:shape": "tsx tests/shape.test.ts",
    "test:smoke": "node tests/smoke.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.279",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.49",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
